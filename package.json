{
  "name": "vite-mui-supabase-starter",
  "private": true,
  "version": "0.26.3",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "vite",
    "build": "tsc --project tsconfig.app.json && vite build",
    "preview": "vite preview",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "eslint . --fix --cache --cache-location .eslintcache",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "type-check": "tsc --noEmit --project tsconfig.app.json",
    "test": "vitest",
    "test:run": "vitest run",
    "test:classify": "node --test scripts/change-classify.test.cjs",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "clean": "gts clean",
    "compile": "tsc",
    "fix": "gts fix",
    "prepare": "husky",
    "arch:check": "depcruise --config .dependency-cruiser.cjs src",
    "arch:check:ci": "depcruise --config .dependency-cruiser.cjs --output-type err-long src",
    "arch:graph": "depcruise --config .dependency-cruiser.cjs --output-type dot src | dot -T svg > architecture-graph.svg",
    "arch:graph:html": "depcruise --config .dependency-cruiser.cjs --output-type html src > architecture-report.html",
    "arch:validate": "pnpm lint && pnpm arch:check",
    "arch:baseline": "depcruise --config .dependency-cruiser.cjs --output-type baseline src > .dependency-cruiser-baseline.json",
    "lint:arch": "eslint src --rule 'boundaries/element-types: error'",
    "validate:structure": "node scripts/project-structure-validator.js",
    "validate:structure:json": "node scripts/project-structure-validator.js --format=json",
    "validate:version-sync": "node scripts/validate-version-sync.js",
    "validate:app-config": "node scripts/validate-app-config.js",
    "validate:docs:links": "node scripts/validate-markdown-links.js",
    "validate:docs:refs": "node scripts/validate-cursor-doc-references.js",
    "validate:docs": "pnpm validate:docs:links && pnpm validate:docs:refs",
    "validate:structure:staged": "node scripts/validate-staged.js",
    "validate:feature-docs": "node scripts/validate-feature-docs.js",
    "validate:feature-docs:strict": "node scripts/validate-feature-docs.js --strict",
    "validate:feature-docs:json": "node scripts/validate-feature-docs.js --format=json",
    "validate:feature-docs:staged": "node scripts/validate-feature-docs-staged.js",
    "arch:check:staged": "node scripts/arch-check-staged.js",
    "airtable:meta-dump": "node scripts/airtable-meta-dump.js",
    "airtable:sample": "node scripts/airtable-sample-records.js"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@supabase/supabase-js": "^2.106.2",
    "airtable": "^0.12.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "dependency-cruiser": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "gts": "^7.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "minimatch": "^10.2.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "projectStructure.config.cjs": [
      "pnpm validate:structure"
    ],
    ".dependency-cruiser.cjs": [
      "pnpm arch:check"
    ]
  }
}
